// cakephp-file-storage — database schema snapshot (DBML)
//
// A merged snapshot of all plugin migrations under config/Migrations/.
// Hand-maintained: update it when you add a migration that changes these tables.
// Paste into https://dbdiagram.io (or any DBML tool) to view/diagram.
// DBML reference: https://dbml.dbdiagram.io/docs
// Need it as a migration or raw SQL? Convert this DBML at https://toolbox.dereuromark.de/dbml
//
// Note: `id` is a CHAR(36) UUID — the file's own identity, generated by the application,
// not an auto-increment integer. `foreign_key` is a polymorphic reference to the owning
// record in your application; its exact type (integer, biginteger, uuid, binaryuuid) is
// determined at migration time by Configure::read('Polymorphic.type', 'integer').
// `user_id` is a plain integer FK to your application's users table.

Project cakephp_file_storage {
  database_type: 'Generic'
  Note: 'File Storage plugin tables only. foreign_key is polymorphic; id is a UUID char(36).'
}

Table file_storage {
  id char(36) [pk, note: 'UUID generated by the application — not an auto-increment integer.']
  user_id integer [null]
  foreign_key int [null, note: 'Polymorphic foreign_key id; set Polymorphic.type to biginteger/uuid/binaryuuid to change']
  model varchar(128) [null]
  filename varchar(255) [null]
  filesize integer [null]
  mime_type varchar(128) [null]
  extension varchar(32) [null]
  hash varchar(64) [null]
  path varchar(255) [null]
  adapter varchar(32) [null]
  created datetime [null]
  modified datetime [null]
  variants json [null]
  metadata json [null]
  collection varchar(128) [null]
}
